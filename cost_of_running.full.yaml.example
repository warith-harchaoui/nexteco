exclusions:
  - "Storage is excluded unless materially relevant"
  - "Network egress is excluded unless materially relevant"

provenance_rules:
  - "Any API price must include source_url and retrieved_date"
  - "If pricing freshness is unclear, downgrade to placeholder or TODO"
  - "Never present estimated values as measured values"

output_expectations:
  generated_files:
    - "cost_of_running.yaml"
    - "cost_of_running.md"
  validation:
    - "tests for arithmetic coherence"
    - "tests for synchronization between YAML and Markdown"
    - "benchmark targeting the canonical unit of work"
  notes:
    - "Use the full template when the cost model should survive over time"
