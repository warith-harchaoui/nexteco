# =======================================================================
# NextEco — cost_of_running.yaml
#
# This file is the single source of truth for the cost model. 
# It is structured to be read by humans and generated by AI agents.
# 
# HOW TO USE:
# 1. Copy `cost_of_running.yaml.example` to `cost_of_running.yaml`.
# 2. Fill in the `deployment` and `workload` sections manually based on 
#    your physical location and intended usage scale.
# 3. Use an AI agent with `core.md` or `advanced.md` to populate the rest.
# =======================================================================

date_updated: "YYYY-MM-DD"

# -----------------------------------------------------------------------
# 1. PHYSICAL & LOGICAL CONTEXT (MANDATORY HUMAN INPUT)
# -----------------------------------------------------------------------
deployment:
  # The provider hosting the compute. (e.g., aws, gcp, azure, on-prem, local)
  provider: "unknown"
  
  # The hardware instance or laptop. (e.g., p3.2xlarge, m2-pro)
  instance_type: "unknown"
  
  # Cloud or physical region. (e.g., eu-west-1, us-central1, local)
  region: "unknown"
  
  # The country is critical! Electricity costs and carbon intensity 
  # vary drastically (e.g., France ~56 gCO₂e/kWh vs Australia ~620 gCO₂e/kWh).
  country: "unknown"

workload:
  # The nature of the task. (e.g., inference, training, batch, api, test)
  type: "unknown"
  
  # Frequency or volume. (e.g., one-off, daily cron, 100_requests_sec)
  scale: "unknown"


# -----------------------------------------------------------------------
# 2. CANONICAL UNIT OF WORK (Populated by AI)
# -----------------------------------------------------------------------
# The single most meaningful operation to anchor cost against.
unit_of_work:
  name: "e.g., one CLI invocation, one API request, one pipeline run"
  description: "Brief summary of what this unit does end-to-end."
  rationale: "Why this unit was chosen over others."


# -----------------------------------------------------------------------
# 3. METHODOLOGY (Populated by AI)
# -----------------------------------------------------------------------
methodology:
  approach: "Green Algorithms-inspired"
  measured_vs_estimated: "What is hard evidence vs. what is guessed."
  
  # Explicit, auditable math used to calculate the scenarios below.
  formula_notes:
    - "energy_kwh = (runtime_s / 3600) * average_power_kw"
    - "local_compute_usd = energy_kwh * electricity_usd_per_kwh"
    - "carbon_gco2e = energy_kwh * carbon_intensity_gco2e_per_kwh"
    - "api_call.cost_usd = (tokens_in * price_in + tokens_out * price_out) / 1_000_000"

  # Benchmark evidence linking the theoretical model to actual hardware.
  benchmark:
    tool: "e.g., pytest-benchmark, perf"
    command: "e.g., pytest tests/benchmark.py --benchmark-only"
    status: "measured|not_run|TODO"
    last_run: "YYYY-MM-DD|not_run"
    hardware: "Hardware context of the run (if measured)."

  # Profiling data explaining *where* the cost originates (Advanced only).
  profiling:
    type: "e.g., cpu, memory, api_call_tracing"
    status: "measured|TODO"


# -----------------------------------------------------------------------
# 4. ASSUMPTIONS (Populated by AI, guided by Deployment country)
# -----------------------------------------------------------------------
assumptions:
  electricity:
    usd_per_kwh: 0.15           # Looked up based on the deployment country
    country: "unknown"          # Should match deployment.country
    source: "e.g., Eurostat, EIA"
    status: "measured|estimated|placeholder"
    
  carbon_intensity:
    gco2e_per_kwh: 400          # Looked up based on the deployment country
    country: "unknown"          # Should match deployment.country
    source: "e.g., Our World in Data"
    status: "measured|estimated|placeholder"
    
  hardware:
    description: "Should match deployment.instance_type"
    average_power_w: 12         # Base or load wattage
    status: "measured|estimated|placeholder"


# -----------------------------------------------------------------------
# 5. SCENARIOS (Populated by AI)
# -----------------------------------------------------------------------
scenarios:
  - name: "typical"
    description: "The baseline execution path."
    
    # ⏱️ TIME
    per_unit:
      runtime_s: 0.0
      
      # 🪫 ENERGY
      energy_kwh: 0.00
      
      # 💰 MONEY
      api_calls:
        # Example schema for external LLM / API calls
        # - name: "generation"
        #   provider: "openai"
        #   model: "gpt-4o"
        #   tokens_in: 1000
        #   tokens_out: 500
        #   price_per_1m_in: 2.50
        #   price_per_1m_out: 10.00
        #   cost_usd: 0.0075
        #   source_url: "https://..."
        #   retrieved_date: "YYYY-MM-DD"
        #   status: "estimated"
      
      total_api_usd: 0.00
      local_compute_usd: 0.00
      total_usd: 0.00
      total_eur: 0.00
      
      # 💨 CARBON
      carbon_gco2e: 0.00

    data_quality: "low|medium|high"
    status:
        runtime: "estimated"
        power: "estimated"
        api_pricing: "estimated"
    notes:
      - "Include any context about the limits of this scenario here."


# -----------------------------------------------------------------------
# 6. INCLUSIONS & EXCLUSIONS
# -----------------------------------------------------------------------
inclusions:
  - "What is counted (e.g., API calls, inference power draw)."
exclusions:
  - "What is ignored (e.g., Model download bandwidth, DB footprint)."


# -----------------------------------------------------------------------
# 7. TODOS
# -----------------------------------------------------------------------
todos:
  - "TODO: Replace placeholders with measured values."
  - "TODO: Run the benchmark script on target hardware."
